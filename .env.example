# ============================================================
# CONFIGURAÇÕES DO FRAMEWORK DE AUTOMAÇÃO DE API
# Copie este arquivo para .env e ajuste conforme o ambiente
# ============================================================
# O .env é o CENTRALIZADOR de variáveis de configuração.
# Acesso à config apenas via GerenciadorDeConfiguracao.
# ============================================================

# ============================================================
# URL DA API
# ============================================================
# URL base da API sob teste (ex.: Portal Colaborador Backend)
# OBRIGATÓRIO
URL_BASE_API=http://localhost:8000

# ============================================================
# AUTENTICAÇÃO
# ============================================================
# Token fixo (se já tiver um); deixe vazio para obter token via login nos testes
API_TOKEN=

# Usuário e senha para login (usados nos testes que fazem login)
USUARIO_LOGIN=maria
SENHA_LOGIN=123456

# ============================================================
# REQUISIÇÕES HTTP
# ============================================================
# Timeout em segundos para requisições
API_TIMEOUT=30

# Verificar certificado SSL (true/false). Use false em ambientes locais com HTTP
API_VERIFICAR_SSL=false

# ============================================================
# RELATÓRIOS
# ============================================================
DIRETORIO_RELATORIOS=./reports

# ============================================================
# LOG / DEBUG
# ============================================================
# Nível de log: DEBUG, INFO, WARNING, ERROR
NIVEL_LOG=INFO
